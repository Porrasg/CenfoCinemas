@page
@model WebApp.Pages.UsersModel
@{
    <script src="~/js/pages-controllers/UserViewController.js"></script>
}
<h1>Mantenimiento de Usuarios</h1>
<div class="bs-docs-section">
    <div class="row">
        <legend>Listado de usuarios</legend>
        <div class="col-lg-12">
            <table id="tblUsers" class="display" style="width:100%">
                <tr>
                    <th>Id</th>
                    <th>User Code</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>BirthDate</th>
                    <th>Status</th>
                    <th>PhoneNumber</th>
                    <th>Created</th>
                </tr>
            </table>
        </div>
    </div>
</div>