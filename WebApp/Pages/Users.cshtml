@page
@model WebApp.Pages.UsersModel
@{
    <script src="~/js/pages-controllers/UserViewController.js"></script>
}
<h1>Mantenimiento de Usuarios</h1>
<div class="bs-docs-section">
    <div class="row">
        <legend>Listado de usuarios</legend>
        <div class="col-lg-12">
            <table id="tblUsers" class="display" style="width:100%">
                <tr>
                    <th>Id</th>
                    <th>User Code</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>BirthDate</th>
                    <th>Status</th>
                    <th>PhoneNumber</th>
                    <th>Created</th>
                </tr>
            </table>
        </div>
    </div>
    <div class="row">
        <div class="cols-lg-6">
            <div class="bs-component">
                <form >
                    <fieldset>
                        <legend>Edicion</legend>
                        <div class="form-group">
                            <label for="txtId" class="form-label mt-4">Id</label>
                            <input id="txtId" readonly type="number" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label for="txtUserCode" class="form-label mt-4">User code</label>
                            <input id="txtUserCode" type="text" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label for="txtName" class="form-label mt-4">Name</label>
                            <input id="txtName" type="text" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label for="txtEmail" class="form-label mt-4">Email</label>
                            <input id="txtEmail" type="email" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label for="txtBirthDate" class="form-label mt-4">Birth Date</label>
                            <input id="txtBirthDate" type="date" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label for="txtStatus" class="form-label mt-4">Status</label>
                            <select id="txtStatus" class="form-control">
                                <option value="">Seleccione...</option>
                                <option value="AC">AC - Activa</option>
                                <option value="IN">IN - Inactiva</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="txtPhoneNumber" class="form-label mt-4">Phone Number</label>
                            <input id="txtPhoneNumber" type="number" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label for="txtPassword" class="form-label mt-4">Password</label>
                            <input id="txtPassword" type="password" class="form-control" />
                        </div>
                    </fieldset>
                </form>
                <br />
                <button id="btnCreate" class="btn btn-primary btn-xs">Create</button>
                <button id="btnUpdate" class="btn btn-secondary btn-xs">Update</button>
                <button id="btnDelete" class="btn btn-danger btn-xs">Delete</button>
            </div>
        </div>
    </div>
</div>